# secrets.yaml — copy this file to secrets.yaml and fill in your values
# secrets.yaml is gitignored and should NEVER be committed

wifi_ssid: "your_primary_wifi_ssid"
wifi_password: "your_primary_wifi_password"
wifi_ssid2: "your_secondary_wifi_ssid"       # second AP (different SSID), or same as primary
wifi_password2: "your_secondary_wifi_password"
